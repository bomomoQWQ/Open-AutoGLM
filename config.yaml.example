# Phone Agent Configuration
# Copy this file to config.yaml and fill in your settings.

model:
  # OpenAI-compatible API endpoint
  base_url: "https://api.openai.com/v1"

  # API key for authentication
  api_key: "sk-xxx"

  # Model name (any OpenAI-compatible vision-language model)
  model_name: "gpt-4o"

  # Model inference parameters
  max_tokens: 3000
  temperature: 0.0
  frequency_penalty: 0.2

  # Language: "cn" for Chinese, "en" for English
  lang: "cn"

device:
  # Device type: "adb" (Android), "hdc" (HarmonyOS), "ios" (iPhone)
  type: "adb"

  # Specific device ID (null = auto-detect)
  id: null

# Maximum steps per task before force-termination
max_steps: 100
